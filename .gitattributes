# Normalize line endings to LF in the repo so files don't perpetually show as
# "modified" on Windows checkouts (core.autocrlf converts to CRLF in the working
# tree, but the committed blob stays LF).
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.mp4 binary
*.mov binary
*.webm binary
*.glb binary
*.pdf binary
*.pptx binary
*.woff binary
*.woff2 binary
*.ttf binary
