DATABASE_URL=postgres://postgres:postgres@localhost:5432/ccy_canvas?sslmode=disable
SESSION_SECRET=01234567890123456789012345678901
# CCY_ENCRYPTION_KEY is base64-encoded 32 bytes (AES-256-GCM key for relay provider API keys)
CCY_ENCRYPTION_KEY=MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTIzNDU2Nzg5MDE=
# Bind to 0.0.0.0 so LAN clients can reach the API.
HTTP_ADDR=0.0.0.0:8080
COOKIE_SECURE=false

# New users can register without an invitation code. If they do not enter
# an invitation code, this quota is used to create their initial credit account.
DEFAULT_DAILY_QUOTA=100

# Optional Google OAuth login. Users with verified Google email addresses
# are auto-created on first login and receive DEFAULT_DAILY_QUOTA credits.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8080/api/auth/google/callback
# Where the backend should redirect after Google login. Use your frontend
# origin in dev, or your production domain when /api is reverse-proxied.
AUTH_FRONTEND_BASE_URL=http://localhost:5173

# Optional Redis cache + durable Asynq generation queue.
# Leave REDIS_ADDR empty to keep the legacy in-process generation path.
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Asset storage. Default local mode keeps writing files to ./uploads and
# returning /uploads/... URLs. Set STORAGE_BACKEND=cos to upload new user
# uploads and generated assets to Tencent Cloud COS.
STORAGE_BACKEND=local
UPLOAD_DIR=uploads
COS_BUCKET=
COS_REGION=
COS_SECRET_ID=
COS_SECRET_KEY=
# Optional: override the bucket endpoint or public URL, e.g. CDN/custom domain.
COS_ENDPOINT=
COS_PUBLIC_BASE_URL=
COS_KEY_PREFIX=ccy-canvas

# ─── Frontend build-time ────────────────────────────────────────────────────
# Frontend's API base URL. Leave empty if frontend is reverse-proxied
# (e.g. nginx serving /api -> backend). Set to http://<lan-ip>:8080 for direct.
PUBLIC_API_BASE=
