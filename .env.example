DATABASE_URL=postgres://postgres:postgres@localhost:5432/ccy_canvas?sslmode=disable
SESSION_SECRET=01234567890123456789012345678901
# CCY_ENCRYPTION_KEY is base64-encoded 32 bytes (AES-256-GCM key for relay provider API keys)
CCY_ENCRYPTION_KEY=MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTIzNDU2Nzg5MDE=
# Bind to 0.0.0.0 so LAN clients can reach the API.
HTTP_ADDR=0.0.0.0:8080
COOKIE_SECURE=false

# Optional Redis cache + durable Asynq generation queue.
# Leave REDIS_ADDR empty to keep the legacy in-process generation path.
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Frontend build-time ────────────────────────────────────────────────────
# Frontend's API base URL. Leave empty if frontend is reverse-proxied
# (e.g. nginx serving /api -> backend). Set to http://<lan-ip>:8080 for direct.
PUBLIC_API_BASE=
